pipeline {
    agent any

    stages {

        stage('Checkout Code') {
            steps {
                git 'https://github.com/your-username/web-project.git'
            }
        }

        stage('Verify Files') {
            steps {
                bat 'dir'
            }
        }
    }

    post {
        success {
            publishHTML(target: [
                reportDir: '.',
                reportFiles: 'index.html',
                reportName: 'Web App',
                keepAll: true,
                alwaysLinkToLastBuild: true
            ])
        }
    }
}
